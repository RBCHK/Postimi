# Database (Prisma + Supabase)
# Runtime queries (Prisma Client via driver adapter) — transaction-mode pooler, port 6543
DATABASE_URL=
# Migrations (prisma migrate deploy) — session-mode pooler, port 5432
DIRECT_URL=

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
# Sign-in lives on the marketing host (postimi.com). In local dev this is an absolute
# URL to the marketing host so that sign-in works from the app subdomain via Clerk SSO.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=http://lvh.me:3000/sign-in
# Where Clerk redirects after successful sign-in. Must be an absolute URL — a relative
# "/" would resolve on the marketing host and dump users on the landing instead of the app.
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=http://app.lvh.me:3000/
# NEXT_PUBLIC_CLERK_SIGN_UP_URL is intentionally absent — public sign-up is blocked by
# Clerk Restricted Mode during the waitlist phase. PR 7 re-introduces an invite-only
# sign-up route inside the app tree.

# Vercel Cron
CRON_SECRET=

# Anthropic (AI SDK) — read automatically by @ai-sdk/anthropic
ANTHROPIC_API_KEY=

# Tavily (web search)
TAVILY_API_KEY=

# X (Twitter) API — OAuth 2.0 PKCE (app-level credentials from Developer Portal)
X_CLIENT_ID=
X_CLIENT_SECRET=

# Threads (Meta) API — OAuth 2.0 (app credentials from Meta Developer Portal)
THREADS_APP_ID=
THREADS_APP_SECRET=

# LinkedIn API — OAuth 2.0 (app credentials from LinkedIn Developer Portal)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Token encryption key for API tokens in DB (generate: openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=

# App URL (app host — used for OAuth callback redirect and absolute links into the dashboard)
# Local dev: http://app.lvh.me:3000  — lvh.me resolves to 127.0.0.1 and supports subdomains + cross-subdomain cookies.
NEXT_PUBLIC_APP_URL=http://app.lvh.me:3000

# Marketing URL (landing + waitlist + legal). Used for absolute links from the app back to marketing.
NEXT_PUBLIC_MARKETING_URL=http://lvh.me:3000

# Supabase Storage (media uploads)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Sentry (error monitoring) — NEXT_PUBLIC_ prefix exposes to client
NEXT_PUBLIC_SENTRY_DSN=

# Stripe (subscription billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Waitlist IP salt (generate: openssl rand -base64 32) — used to hash IPs for rate limiting
WAITLIST_IP_SALT=
