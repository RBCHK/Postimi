// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ContentType {
  REPLY
  POST
  THREAD
  ARTICLE
}

enum ConversationStatus {
  DRAFT
  SCHEDULED
  POSTED
}

enum SlotType {
  POST
  REPLY
  THREAD
  ARTICLE
}

enum SlotStatus {
  EMPTY
  FILLED
  POSTED
}

enum VoiceBankType {
  REPLY
  POST
}

model Conversation {
  id                String              @id @default(cuid())
  title             String
  contentType       ContentType
  status            ConversationStatus  @default(DRAFT)
  originalPostText  String?
  originalPostUrl   String?
  pinned            Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  lastActivityAt    DateTime            @default(now())

  messages Message[]
  notes    Note[]
  slots    ScheduledSlot[]
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // "user" | "assistant"
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Note {
  id             String   @id @default(cuid())
  conversationId String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model VoiceBankEntry {
  id        String         @id @default(cuid())
  content   String
  type      VoiceBankType
  topic     String?
  createdAt DateTime       @default(now())
}

model ScheduledSlot {
  id             String     @id @default(cuid())
  date           DateTime
  timeSlot       String
  slotType       SlotType
  status         SlotStatus @default(EMPTY)
  content        String?
  conversationId String?
  postedAt       DateTime?

  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
}

model StrategyConfig {
  id                 String   @id @default(cuid())
  postsPerDay        Int      @default(2)
  replySessionsPerDay Int      @default(4)
  timeSlots          Json     // e.g. ["9:00 AM", "12:00 PM", "3:00 PM", "6:00 PM"]
  scheduleConfig     Json?    // { posts: { slots: [...] }, threads: {...}, articles: {...} }
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

enum XPostType {
  POST
  REPLY
}

model XPost {
  id            String    @id @default(cuid())
  postId        String    @unique
  date          DateTime
  text          String
  postLink      String?
  postType      XPostType
  impressions   Int       @default(0)
  likes         Int       @default(0)
  engagements   Int       @default(0)
  bookmarks     Int       @default(0)
  shares        Int       @default(0)
  newFollowers  Int       @default(0)
  replies       Int       @default(0)
  reposts       Int       @default(0)
  profileVisits Int       @default(0)
  detailExpands Int       @default(0)
  urlClicks     Int       @default(0)
  createdAt     DateTime  @default(now())
}

model DailyAccountStats {
  id            String   @id @default(cuid())
  date          DateTime @unique
  impressions   Int      @default(0)
  likes         Int      @default(0)
  engagements   Int      @default(0)
  bookmarks     Int      @default(0)
  shares        Int      @default(0)
  newFollows    Int      @default(0)
  unfollows     Int      @default(0)
  replies       Int      @default(0)
  reposts       Int      @default(0)
  profileVisits Int      @default(0)
  createPost    Int      @default(0)
  videoViews    Int      @default(0)
  mediaViews    Int      @default(0)
  createdAt     DateTime @default(now())
}

model StrategyAnalysis {
  id             String   @id @default(cuid())
  csvSummary     Json     // { totalPosts, avgImpressions, topPosts[], dateRange }
  searchQueries  String[] // queries the agent ran, for transparency
  recommendation String   // full markdown output from Claude
  weekStart      DateTime // the Monday of the week this analysis covers
  createdAt      DateTime @default(now())
}
